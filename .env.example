# Copia este archivo a .env.local para desarrollo local (no se sube a git).
# En producción, estas variables se configuran en Vercel → Settings → Environment Variables.

# Tu API key de ElevenLabs (la misma que ya usas en el proyecto local, en .env)
ELEVENLABS_API_KEY=

# Se rellena solo cuando conectas un Blob store al proyecto desde el dashboard de Vercel.
# No hace falta copiarlo a mano si el store está vinculado al proyecto.
BLOB_READ_WRITE_TOKEN=
